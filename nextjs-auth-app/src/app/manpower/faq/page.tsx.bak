'use client';

import Link from 'next/link';

const faqs = [
  {
    q: 'How are officer counts calculated?',
    a: 'You set the total number of officers you have available. Those officers are then distributed across precincts in direct proportion to each precinct’s forecasted crime volume — a precinct with twice the predicted crime of another receives roughly twice the officers. This is a relative allocation of a fixed budget, not a fixed “officers per incident” rule.',
  },
  {
    q: 'How is the split kept fair when numbers don’t divide evenly?',
    a: 'Allocation uses the largest-remainder method. Each precinct first gets the whole-number (floor) of its proportional share, then any leftover officers are handed out one at a time to the precincts with the largest fractional remainder. This guarantees the totals always add up exactly to your available officer count.',
  },
  {
    q: 'How are shifts distributed within a precinct?',
    a: 'Each precinct’s allocated officers are further split across the three 8-hour shifts — Morning (6:00 AM – 2:00 PM), Afternoon (2:00 PM – 10:00 PM), and Evening (10:00 PM – 6:00 AM) — in proportion to the crime forecasted in each shift. The same largest-remainder method keeps the shift totals consistent with the precinct total.',
  },
  {
    q: 'What does the trend indicator (↑ ↓) mean?',
    a: 'The trend reflects the majority direction of the individual forecast predictions in a precinct: ↑ if more predictions are increasing, ↓ if more are decreasing, and stable otherwise. It is informational and does not change the officer allocation, which is based on predicted volume.',
  },
  {
    q: 'Where does the forecast data come from?',
    a: 'The manpower plan uses predictions from the SSA (Singular Spectrum Analysis) forecasting model. Historical crime data is analyzed for seasonal patterns and trends, then projected forward for the configured forecast period. The forecast is generated on the Forecasting page and reviewed on the Shift Distribution tab before being passed to this page.',
  },
  {
    q: 'Can I adjust the allocation after it is generated?',
    a: 'Yes. Change the “Available Officers” value to rebalance the entire plan instantly. Published proposals are saved locally, and you can fine-tune individual allocations on the Precinct Management page, which stores records to the backend API.',
  },
];

export default function ManpowerFaqPage() {
  return (
    <div className="max-w-3xl mx-auto p-6 space-y-6">
      <Link href="/manpower" className="text-ubuntu-600 hover:text-blue-800 text-sm flex items-center">
        ← Back to Manpower Plan
      </Link>

      <div>
        <h1 className="text-2xl font-bold text-gray-900">Manpower Allocation — FAQ</h1>
        <p className="text-gray-500 mt-1">How the numbers are derived, what the assumptions mean, and where the data comes from.</p>
      </div>

      <div className="space-y-4">
        {faqs.map((faq, i) => (
          <details key={i} className="bg-white border border-gray-200 rounded-lg overflow-hidden open:shadow-sm">
            <summary className="px-5 py-4 text-sm font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 select-none">
              {faq.q}
            </summary>
            <div className="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-3">
              {faq.a}
            </div>
          </details>
        ))}
      </div>

      <div className="text-xs text-gray-400 text-center pt-4 border-t border-gray-200">
        These explanations describe the current planning model. All constants and thresholds are configurable.
      </div>
    </div>
  );
}
